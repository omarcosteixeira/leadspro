rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/artifacts/gestaopro-761e1/public/data/users/$(request.auth.uid)).data;
    }
    
    function isMasterUser() {
      return isAuthenticated() && (
        request.auth.token.email == "canaldonutri@gmail.com" || 
        request.auth.token.email == "marcos.teixeira@estacio.br" ||
        (exists(/databases/$(database)/documents/artifacts/gestaopro-761e1/public/data/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/artifacts/gestaopro-761e1/public/data/users/$(request.auth.uid)).data.role == "Admin Master")
      );
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() && (
        isMasterUser() ||
        (exists(/databases/$(database)/documents/artifacts/gestaopro-761e1/public/data/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/artifacts/gestaopro-761e1/public/data/users/$(request.auth.uid)).data.role in roles)
      );
    }
    
    function isAdminMaster() { return hasAnyRole(['Admin Master']); }
    function isPrincipal() { return isAdminMaster(); }
    function isLider() { return hasAnyRole(['Líder/FDV']); }
    function isSalaMatricula() { return hasAnyRole(['Sala de Matrícula']); }
    function isQG() { return hasAnyRole(['QG']); }
    function isFDV() { return hasAnyRole(['FDV', 'FDV (Comercial)']); }
    function isPromotor() { return hasAnyRole(['Promotor', 'Promotor/rua']); }
    function isSSA() { return hasAnyRole(['SSA']); }
    function isGestorUnidade() { return hasAnyRole(['Gestor Unidade']); }
    function isGestorComercial() { return hasAnyRole(['Gestor Comercial', 'Gerente Comercial (Comercial)']); }
    function isComercial() { return isGestorComercial(); }
    function isAcademico() { return hasAnyRole(['Acadêmico']); }
    function isFinanceiro() { return hasAnyRole(['Financeiro']); }
    function isTecnico() { return hasAnyRole(['Técnico']); }

    function isRestrictedRole(role) {
      return !(role in ['Admin Master', 'Gestor Comercial', 'Gerente Comercial (Comercial)']);
    }

    function canAccessUnit(unidade, userRole, userUnidade) {
      return !isRestrictedRole(userRole) || (unidade == userUnidade);
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.name is string &&
             data.role in ['Admin Master', 'Promotor', 'FDV', 'Sala de Matrícula', 'QG', 'Líder/FDV', 'SSA', 'Gestor Unidade', 'Gestor Comercial', 'Acadêmico', 'Gerente Comercial (Comercial)', 'FDV (Comercial)', 'Promotor/rua', 'Financeiro', 'Técnico'] &&
             (!('unidade' in data) || data.unidade is string);
    }

    function isValidCalendarioAcao(data) {
      return data.keys().hasAll(['nome', 'dataInicio', 'dataFim', 'unidade', 'creatorId']) &&
             data.nome is string && data.nome.size() <= 1000 &&
             data.unidade is string &&
             data.creatorId == request.auth.uid;
    }

    function isValidEmpresa(data) {
      return data.keys().hasAll(['nome', 'responsavel', 'telefone']) &&
             data.nome is string && data.nome.size() > 0 &&
             data.responsavel is string &&
             data.telefone is string;
    }

    function isValidWhatsAppMessage(data) {
      return data.keys().hasAll(['tipo', 'texto']) &&
             data.tipo is string &&
             data.texto is string;
    }

    function isValidMapaoAcademico(data) {
      return data.keys().hasAll(['modalidade', 'curso', 'tipoCurso']) &&
             data.modalidade is string &&
             data.curso is string;
    }

    function isValidFiesProuni(data) {
      return data.keys().hasAll(['nome', 'cpf', 'tipo', 'bolsa', 'curso', 'unidade']) &&
             data.nome is string &&
             data.cpf is string &&
             data.unidade is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /artifacts/gestaopro-761e1/public/data/users/{userId} {
      allow get: if isAuthenticated() && (userId == request.auth.uid || canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade))
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (userId == request.auth.uid || isMasterUser())
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isMasterUser() || (userId == request.auth.uid && request.resource.data.role == resource.data.role && request.resource.data.unidade == resource.data.unidade))
      allow delete: if isMasterUser()
    }

    match /artifacts/gestaopro-761e1/public/data/leads/{leadId} {
      allow get: if isAuthenticated() && canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade)
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow create: if (isMasterUser() || isComercial() || request.auth == null) && (
        request.auth == null || canAccessUnit(request.resource.data.unidade, getUserData().role, getUserData().unidade)
      )
      allow update: if (isMasterUser() || isComercial()) && 
        canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade) && 
        canAccessUnit(request.resource.data.unidade, getUserData().role, getUserData().unidade)
      allow delete: if isMasterUser() || isComercial()
    }

    match /artifacts/gestaopro-761e1/public/data/bases/{baseId} {
      allow get: if isAuthenticated() && canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade)
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow create, update, delete: if isMasterUser() || isComercial()
    }

    match /artifacts/gestaopro-761e1/public/data/gap_academico/{gapId} {
      allow get: if isAuthenticated() && canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade)
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow create, update: if (isMasterUser() || isComercial()) && canAccessUnit(request.resource.data.unidade, getUserData().role, getUserData().unidade)
      allow delete: if isMasterUser() || isComercial()
    }

    match /artifacts/gestaopro-761e1/public/data/fies_prouni/{entryId} {
      allow get: if isAuthenticated() && canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade)
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow create, update: if (isMasterUser() || isComercial()) && canAccessUnit(request.resource.data.unidade, getUserData().role, getUserData().unidade)
      allow delete: if isMasterUser() || isComercial()
    }
    match /artifacts/gestaopro-761e1/public/data/fies_prouni_vagas/{entryId} {
      allow get: if isAuthenticated() && canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade)
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow create, update: if (isMasterUser() || isComercial()) && canAccessUnit(request.resource.data.unidade, getUserData().role, getUserData().unidade)
      allow delete: if isMasterUser() || isComercial()
    }

    match /artifacts/gestaopro-761e1/public/data/calendario_acoes/{acaoId} {
      allow get: if isAuthenticated() && canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade)
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow create: if (isMasterUser() || isComercial() || isFinanceiro()) && isValidCalendarioAcao(request.resource.data) && canAccessUnit(request.resource.data.unidade, getUserData().role, getUserData().unidade)
      allow update: if (isMasterUser() || isComercial() || isFinanceiro()) && isValidCalendarioAcao(request.resource.data) && canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade) && canAccessUnit(request.resource.data.unidade, getUserData().role, getUserData().unidade)
      allow delete: if (isMasterUser() || isComercial() || isFinanceiro()) && canAccessUnit(resource.data.unidade, getUserData().role, getUserData().unidade)
    }

    match /artifacts/gestaopro-761e1/public/data/pedido_cursos/{id} {
      allow create: if true
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow get, update, delete: if isAuthenticated() && (isMasterUser() || isComercial() || resource.data.unidade == getUserData().unidade)
    }

    match /artifacts/gestaopro-761e1/public/data/qg_ligacoes/{id} {
      allow read: if isAuthenticated()
      allow write: if isPrincipal() || isComercial() || isSSA()
    }
    match /artifacts/gestaopro-761e1/public/data/controle_concorrencia/{id} {
      allow read: if isAuthenticated()
      allow write: if isPrincipal() || isComercial() || isSSA()
    }

    match /artifacts/gestaopro-761e1/public/data/campanhas/{id} {
      allow read: if isAuthenticated()
      allow write: if isPrincipal() || isComercial() || isSSA()
    }
    match /artifacts/gestaopro-761e1/public/data/bom_dia/{id} {
      allow read: if isAuthenticated()
      allow write: if isPrincipal() || isComercial() || isSSA()
    }
    match /artifacts/gestaopro-761e1/public/data/forecast/{id} {
      allow read: if isAuthenticated()
      allow write: if isPrincipal() || isComercial() || isSSA()
    }
    match /artifacts/gestaopro-761e1/public/data/planner/{id} {
      allow read: if isAuthenticated()
      allow write: if isPrincipal() || isComercial() || isSSA()
    }
    match /artifacts/gestaopro-761e1/public/data/periodo_captacao/{id} {
      allow read: if isAuthenticated()
      allow write: if isPrincipal() || isComercial() || isSSA()
    }
    match /artifacts/gestaopro-761e1/public/data/linksUteis/{id} {
      allow read: if isAuthenticated()
      allow write: if isPrincipal() || isComercial() || isSSA()
    }
    match /artifacts/gestaopro-761e1/public/data/empresas_parceiras/{id} {
      allow read: if true
      allow create, update: if (isPrincipal() || isComercial()) && isValidEmpresa(request.resource.data)
      allow delete: if isPrincipal() || isComercial()
    }
    match /artifacts/gestaopro-761e1/public/data/whatsapp_messages/{id} {
      allow read: if isAuthenticated()
      allow create, update: if (hasAnyRole(["SSA", "Admin Master", "Gestor Unidade", "Líder/FDV", "Sala de Matrícula", "QG", "FDV", "FDV (Comercial)", "Promotor", "Promotor/rua", "Gestor Comercial", "Gerente Comercial (Comercial)"])) && isValidWhatsAppMessage(request.resource.data)
      allow delete: if hasAnyRole(["SSA", "Admin Master", "Gestor Unidade", "Líder/FDV", "Sala de Matrícula", "QG", "FDV", "FDV (Comercial)", "Promotor", "Promotor/rua", "Gestor Comercial", "Gerente Comercial (Comercial)"])
    }

    match /artifacts/gestaopro-761e1/public/data/mapao_academico/{id} {
      allow read: if isPrincipal() || isComercial() || isAcademico() || isSSA() || isFinanceiro() || isTecnico()
      allow create, update: if (isPrincipal() || isComercial() || isAcademico() || isSSA() || isFinanceiro() || isTecnico()) && isValidMapaoAcademico(request.resource.data)
      allow delete: if isPrincipal() || isAcademico() || isSSA() || isFinanceiro() || isTecnico()
    }

    match /artifacts/gestaopro-761e1/public/data/bases_disparo/{id} {
      allow read, create, update: if isPrincipal() || isComercial()
      allow delete: if isPrincipal() || isComercial()
    }

    match /artifacts/gestaopro-761e1/public/data/bot_config/{id} {
      allow read: if true
      allow write: if isAuthenticated()
    }

    match /artifacts/gestaopro-761e1/public/data/bot_reports/{id} {
      allow read: if isPrincipal() || isComercial()
      allow create: if isAuthenticated()
      allow update, delete: if isPrincipal()
    }

    match /artifacts/gestaopro-761e1/public/data/bases_renovacao/{id} {
      allow read, create, update: if hasAnyRole(["SSA", "Admin Master", "Gestor Unidade", "Líder/FDV", "Sala de Matrícula", "QG", "FDV", "FDV (Comercial)", "Promotor", "Promotor/rua", "Gestor Comercial", "Gerente Comercial (Comercial)"])
      allow delete: if hasAnyRole(["SSA", "Admin Master", "Gestor Unidade", "Líder/FDV", "Sala de Matrícula", "QG", "FDV", "FDV (Comercial)", "Promotor", "Promotor/rua", "Gestor Comercial", "Gerente Comercial (Comercial)"])
    }

    match /artifacts/gestaopro-761e1/public/data/meta_dia/{id} {
      allow read: if isAuthenticated()
      allow write: if isPrincipal() || isComercial()
    }

    match /artifacts/gestaopro-761e1/public/data/solicitacoes_folga/{id} {
      allow read, write: if isAuthenticated()
    }

    match /artifacts/gestaopro-761e1/public/data/cursos/{id} {
      allow read: if true
      allow write: if isAuthenticated() && (isPrincipal() || isComercial() || isAcademico() || isSSA() || isFinanceiro() || isTecnico())
    }

    match /artifacts/gestaopro-761e1/public/data/insumos_pedidos/{id} {
      allow create: if true
      allow read, update, delete: if isAuthenticated() && (isPrincipal() || isComercial() || isAcademico() || isFinanceiro() || isTecnico())
    }

    match /artifacts/gestaopro-761e1/public/data/insumos_estoque/{id} {
      allow read, write: if isAuthenticated() && (isPrincipal() || isComercial() || isAcademico() || isFinanceiro() || isTecnico())
    }

    match /artifacts/gestaopro-761e1/public/data/insumos_pedidos_comercial/{id} {
      allow create: if true
      allow read, update, delete: if isAuthenticated() && (isPrincipal() || isComercial())
    }

    match /artifacts/gestaopro-761e1/public/data/insumos_estoque_comercial/{id} {
      allow read, write: if isAuthenticated() && (isPrincipal() || isComercial())
    }

    match /artifacts/gestaopro-761e1/public/data/insumos_baixas/{id} {
      allow create: if isAuthenticated()
      allow read, update, delete: if isAuthenticated() && (isPrincipal() || isComercial() || isAcademico() || isFinanceiro() || isTecnico())
    }

    match /artifacts/gestaopro-761e1/public/data/insumos_baixas_comercial/{id} {
      allow create: if isAuthenticated()
      allow read, update, delete: if isAuthenticated() && (isPrincipal() || isComercial())
    }

    match /artifacts/gestaopro-761e1/public/data/funcionarios/{id} {
      allow read: if true
      allow write: if isAuthenticated() && (isPrincipal() || isComercial())
    }

    match /artifacts/gestaopro-761e1/public/data/isencoes/{isencaoId} {
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow get, write: if isAuthenticated() && (isMasterUser() || isComercial() || resource.data.unidade == getUserData().unidade)
    }

    match /artifacts/gestaopro-761e1/public/data/evasao/{id} {
      allow list: if isAuthenticated() && (!isRestrictedRole(getUserData().role) || resource.data.unidade == getUserData().unidade)
      allow get, write: if isAuthenticated() && (isMasterUser() || isComercial() || resource.data.unidade == getUserData().unidade) &&
        hasAnyRole(["SSA", "Admin Master", "Gestor Unidade", "Líder/FDV", "Sala de Matrícula", "QG", "FDV", "FDV (Comercial)", "Promotor", "Promotor/rua", "Gestor Comercial", "Gerente Comercial (Comercial)"])
    }
  }
}
