rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      let isRootUser = exists(/databases/$(database)/documents/users/$(request.auth.uid));
      let isWorkspaceMain = exists(/databases/$(database)/documents/artifacts/gestaopro-761e1/public/data/users/$(request.auth.uid));
      let isWorkspaceFdv = exists(/databases/$(database)/documents/artifacts/gestaopro-761e1/public/data_fdv/users/$(request.auth.uid));
      
      return isRootUser ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role :
             isWorkspaceMain ? get(/databases/$(database)/documents/artifacts/gestaopro-761e1/public/data/users/$(request.auth.uid)).data.role :
             isWorkspaceFdv ? get(/databases/$(database)/documents/artifacts/gestaopro-761e1/public/data_fdv/users/$(request.auth.uid)).data.role :
             null;
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() && (
        request.auth.token.email == "canaldonutri@gmail.com" || 
        request.auth.token.email == "marcos.teixeira@estacio.br" ||
        (getUserRole() in roles)
      );
    }
    
    function isAdminMaster() { return hasAnyRole(['Admin Master']); }
    function isLider() { return hasAnyRole(['Líder/FDV']); }
    function isSalaMatricula() { return hasAnyRole(['Sala de Matrícula']); }
    function isQG() { return hasAnyRole(['QG']); }
    function isFDV() { return hasAnyRole(['FDV']); }
    function isPromotor() { return hasAnyRole(['Promotor']); }
    function isSSA() { return hasAnyRole(['SSA']); }
    function isGestorUnidade() { return hasAnyRole(['Gestor Unidade']); }
    function isGestorComercial() { return hasAnyRole(['Gestor Comercial']); }
    function isAcademico() { return hasAnyRole(['Acadêmico']); }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validation Helpers
    function isValidUser(data) {
      return !('role' in data) || data.role in ['Admin Master', 'Promotor', 'FDV', 'Sala de Matrícula', 'QG', 'Líder/FDV', 'SSA', 'Gestor Unidade', 'Gestor Comercial', 'Acadêmico'];
    }

    function isValidEmpresa(data) {
      return true;
    }

    function isValidWhatsAppMessage(data) {
      return true;
    }

    function isValidMapaoAcademico(data) {
      return true;
    }

    function isValidBaseDisparo(data) {
      return true;
    }

    function isValidFiesProuni(data) {
      return true;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdminMaster() || isLider() || isGestorComercial());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdminMaster() || isLider() || isGestorComercial() || (isOwner(userId) && request.resource.data.role == resource.data.role));
      allow delete: if isAdminMaster() || isLider() || isGestorComercial();
    }

    match /leads/{leadId} {
      allow read: if isLider() || isSalaMatricula() || isQG() || isGestorUnidade() ||
                     (isFDV() && (resource.data.promotorId == request.auth.uid || resource.data.promotorRole == 'Promotor')) ||
                     (isGestorComercial() && (resource.data.promotorId == request.auth.uid || resource.data.promotorRole in ['Promotor', 'FDV'])) ||
                     (isPromotor() && resource.data.promotorId == request.auth.uid);
      allow create: if isLider() || isSalaMatricula() || isQG() || isFDV() || isPromotor() || isGestorUnidade() || isGestorComercial();
      allow update: if isLider() || isSalaMatricula() || isQG() || isGestorUnidade() ||
                      (isFDV() && (resource.data.promotorId == request.auth.uid || resource.data.promotorRole == 'Promotor')) ||
                      (isGestorComercial() && (resource.data.promotorId == request.auth.uid || resource.data.promotorRole in ['Promotor', 'FDV'])) ||
                      (isPromotor() && resource.data.promotorId == request.auth.uid);
      allow delete: if isLider();
    }

    match /bases/{baseId} {
      allow read: if isLider() || isSalaMatricula() || isQG();
      allow create, update: if isLider() || isSalaMatricula();
      allow delete: if isLider();
    }

    match /gap_academico/{gapId} {
      allow read, create, update: if isLider() || isSalaMatricula();
      allow delete: if isLider();
    }

    match /fies_prouni/{entryId} {
      allow read: if isLider() || isSalaMatricula() || isSSA();
      allow create, update: if (isLider() || isSalaMatricula() || isSSA()) && isValidFiesProuni(request.resource.data);
      allow delete: if isLider();
    }

    match /calendario_acoes/{acaoId} {
      allow read: if isLider() || isSalaMatricula() || isGestorUnidade() || isGestorComercial() ||
                     (isFDV() && (resource.data.creatorId == request.auth.uid || resource.data.creatorRole == 'Promotor'));
      allow create, update: if isLider() || isSalaMatricula() || isFDV() || isGestorUnidade() || isGestorComercial();
      allow delete: if isLider();
    }

    // Dashboard & Config Collections
    match /campanhas/{id} {
      allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
      allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
    }
    match /bom_dia/{id} {
      allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
      allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
    }
    match /forecast/{id} {
      allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
      allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
    }
    match /planner/{id} {
      allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
      allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
    }
    match /periodo_captacao/{id} {
      allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
      allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
    }
    match /linksUteis/{id} {
      allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
      allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
    }
    match /empresas_parceiras/{id} {
      allow read: if isAuthenticated();
      allow create, update: if (isAdminMaster() || isLider() || isGestorComercial()) && isValidEmpresa(request.resource.data);
      allow delete: if isAdminMaster() || isLider() || isGestorComercial();
    }
    match /whatsapp_messages/{id} {
      allow read: if isAuthenticated();
      allow create, update: if (isAdminMaster() || isLider() || isSSA() || isSalaMatricula() || isQG() || isGestorComercial()) && isValidWhatsAppMessage(request.resource.data);
      allow delete: if isAdminMaster() || isLider() || isGestorComercial();
    }

    match /mapao_academico/{id} {
      allow read: if isLider() || isAcademico() || isSalaMatricula() || isFDV() || isSSA() || isGestorUnidade() || isGestorComercial();
      allow create, update: if (isLider() || isAcademico()) && isValidMapaoAcademico(request.resource.data);
      allow delete: if isLider() || isAcademico();
    }

    match /bases_disparo/{id} {
      allow read, create, update: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
      allow delete: if isLider();
    }

    match /bot_config/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /bases_renovacao/{id} {
      allow read: if isLider() || isSSA() || isAdminMaster();
      allow create, update: if isLider() || isSSA() || isAdminMaster();
      allow delete: if isLider() || isAdminMaster();
    }

    match /artifacts/gestaopro-761e1/public/{dataPrefix} {
      match /users/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdminMaster() || isLider() || isGestorComercial());
        allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdminMaster() || isLider() || isGestorComercial() || (isOwner(userId) && request.resource.data.role == resource.data.role));
        allow delete: if isAdminMaster() || isLider() || isGestorComercial();
      }

      match /leads/{leadId} {
        allow read: if isLider() || isSalaMatricula() || isQG() || isGestorUnidade() ||
                       (isFDV() && (resource.data.promotorId == request.auth.uid || resource.data.promotorRole == 'Promotor')) ||
                       (isGestorComercial() && (resource.data.promotorId == request.auth.uid || resource.data.promotorRole in ['Promotor', 'FDV'])) ||
                       (isPromotor() && resource.data.promotorId == request.auth.uid);
        allow create: if isLider() || isSalaMatricula() || isQG() || isFDV() || isPromotor() || isGestorUnidade() || isGestorComercial();
        allow update: if isLider() || isSalaMatricula() || isQG() || isGestorUnidade() ||
                        (isFDV() && (resource.data.promotorId == request.auth.uid || resource.data.promotorRole == 'Promotor')) ||
                        (isGestorComercial() && (resource.data.promotorId == request.auth.uid || resource.data.promotorRole in ['Promotor', 'FDV'])) ||
                        (isPromotor() && resource.data.promotorId == request.auth.uid);
        allow delete: if isLider();
      }

      match /bases/{baseId} {
        allow read: if isLider() || isSalaMatricula() || isQG();
        allow create, update: if isLider() || isSalaMatricula();
        allow delete: if isLider();
      }

      match /gap_academico/{gapId} {
        allow read, create, update: if isLider() || isSalaMatricula();
        allow delete: if isLider();
      }

      match /fies_prouni/{entryId} {
        allow read: if isLider() || isSalaMatricula() || isSSA();
        allow create, update: if (isLider() || isSalaMatricula() || isSSA()) && isValidFiesProuni(request.resource.data);
        allow delete: if isLider();
      }

      match /calendario_acoes/{acaoId} {
        allow read: if isLider() || isSalaMatricula() || isGestorUnidade() || isGestorComercial() ||
                       (isFDV() && (resource.data.creatorId == request.auth.uid || resource.data.creatorRole == 'Promotor'));
        allow create, update: if isLider() || isSalaMatricula() || isFDV() || isGestorUnidade() || isGestorComercial();
        allow delete: if isLider();
      }

      // Dashboard & Config Collections
      match /campanhas/{id} {
        allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
        allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
      }
      match /bom_dia/{id} {
        allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
        allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
      }
      match /forecast/{id} {
        allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
        allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
      }
      match /planner/{id} {
        allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
        allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
      }
      match /periodo_captacao/{id} {
        allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
        allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
      }
      match /linksUteis/{id} {
        allow read: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
        allow write: if isAdminMaster() || isLider() || isGestorUnidade() || isGestorComercial();
      }
      match /empresas_parceiras/{id} {
        allow read: if isAuthenticated();
        allow create, update: if (isAdminMaster() || isLider() || isGestorComercial()) && isValidEmpresa(request.resource.data);
        allow delete: if isAdminMaster() || isLider() || isGestorComercial();
      }
      match /whatsapp_messages/{id} {
        allow read: if isAuthenticated();
        allow create, update: if (isAdminMaster() || isLider() || isSSA() || isSalaMatricula() || isQG() || isGestorComercial()) && isValidWhatsAppMessage(request.resource.data);
        allow delete: if isAdminMaster() || isLider() || isGestorComercial();
      }

      match /mapao_academico/{id} {
        allow read: if isLider() || isAcademico() || isSalaMatricula() || isFDV() || isSSA() || isGestorUnidade() || isGestorComercial();
        allow create, update: if (isLider() || isAcademico()) && isValidMapaoAcademico(request.resource.data);
        allow delete: if isLider() || isAcademico();
      }

      match /bases_disparo/{id} {
        allow read, create, update: if isLider() || isSalaMatricula() || isQG() || isFDV() || isGestorUnidade() || isGestorComercial();
        allow delete: if isLider();
      }

      match /bot_config/{id} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      match /bases_renovacao/{id} {
        allow read: if isLider() || isSSA() || isAdminMaster();
        allow create, update: if isLider() || isSSA() || isAdminMaster();
        allow delete: if isLider() || isAdminMaster();
      }
    }
  }
}
